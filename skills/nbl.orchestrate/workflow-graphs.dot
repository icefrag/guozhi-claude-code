digraph orchestrate_workflows {
    rankdir=TB;
    node [shape=box style=filled];

    // Entry point
    orchestrate [shape=doublecircle fillcolor=lightblue label="orchestrate skill\n(Entry Point)"];

    // Workflow branches
    subgraph cluster_feature {
        label="Feature Workflow";
        style=filled;
        color=lightgray;

        brainstorming [fillcolor=lightgreen label="brainstorming\n(Main Window)"];
        writing_plans [fillcolor=lightpink label="writing-plans"];
        choose_mode [shape=diamond fillcolor=lightyellow label="Execution Mode?"];
        parallel_exec [fillcolor=lightpink label="parallel-subagent-\ndriven-development"];
        sequential_exec [fillcolor=lightpink label="subagent-driven-\ndevelopment"];
        parallel_session [fillcolor=lightpink label="executing-plans\n(no subagent support)"];
        code_review [fillcolor=lightpink label="requesting-code-review"];
        finish [fillcolor=lightpink label="finishing-a-development-branch"];
    }

    subgraph cluster_bugfix {
        label="Bugfix Workflow";
        style=filled;
        color=lightgray;

        reproduce [fillcolor=lightgreen label="Reproduce bug"];
        tdd [fillcolor=lightpink label="test-driven-development"];
        cr [fillcolor=lightpink label="requesting-code-review"];
        commit [fillcolor=lightblue label="Commit"];
    }

    subgraph cluster_refactor {
        label="Refactor Workflow";
        style=filled;
        color=lightgray;

        scope [fillcolor=lightgreen label="Define scope"];
        worktree_r [fillcolor=lightpink label="using-git-worktrees"];
        baseline [fillcolor=lightpink label="TDD baseline"];
        refactor [fillcolor=lightpink label="Refactor"];
        finish_r [fillcolor=lightpink label="finishing-a-development-branch"];
    }

    // Feature flow
    orchestrate -> brainstorming;
    brainstorming -> writing_plans;
    writing_plans -> choose_mode;
    choose_mode -> parallel_exec [label="parallelizable\ntasks"];
    choose_mode -> sequential_exec [label="tightly\ncoupled"];
    choose_mode -> parallel_session [label="no subagent\nsupport"];
    parallel_exec -> code_review;
    sequential_exec -> code_review;
    parallel_session -> code_review;
    code_review -> finish;

    // Bugfix flow
    orchestrate -> reproduce [label="bugfix"];
    reproduce -> tdd;
    tdd -> cr;
    cr -> commit;

    // Refactor flow
    orchestrate -> scope [label="refactor"];
    scope -> worktree_r;
    worktree_r -> baseline;
    baseline -> refactor;
    refactor -> finish_r;

    // Code review feedback loop
    code_review -> brainstorming [label="CR issues" style=dashed color=red];
    cr -> tdd [label="CR issues" style=dashed color=red];
}
